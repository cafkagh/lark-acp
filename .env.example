# --- Bot home / state directory (defaults match `~/.claude` convention) ---
# Where logs, chat configs, ACP session bindings live. Default: ~/.lark-acp
# LARK_ACP_HOME=/Users/you/.lark-acp
# Default cwd for new chats (used as agent workdir before any /new is run).
# Default: wherever you launched the bot from.
# LARK_ACP_DEFAULT_WORKDIR=/Users/you/code

# --- Lark / Feishu identity (required for ACL) ---
# Comma-separated list of allowed open_id. Leave empty for INSECURE mode (warn-only).
ALLOWED_OPEN_IDS=ou_xxx,ou_yyy
OWNER_OPEN_ID=ou_owner
# Optional: bot's own open_id; auto-discovered via /open-apis/bot/v3/info if unset.
BOT_OPEN_ID=

# --- Default reply mode ---
# strict | owner | all   (per-chat overridable via /mode)
REPLY_MODE=strict

# --- Default agent (one of the registered backend names) ---
# codex | claude
AGENT_DEFAULT=codex

# --- Override the spawn command for each backend (otherwise: npx <pkg>) ---
# AGENT_CODEX_CMD=codex-acp
# AGENT_CLAUDE_CMD=claude-agent-acp

# --- Backend credentials ---
# Codex needs one of these:
# OPENAI_API_KEY=sk-...
# CODEX_API_KEY=...
# Claude needs:
# ANTHROPIC_API_KEY=sk-ant-...

# --- Timing knobs ---
# Idle agent subprocess eviction (seconds; 0 disables).
AGENT_IDLE_EVICT_SECS=900
# Per-prompt cancel grace (ms) before SIGKILL on subprocess.
AGENT_CANCEL_GRACE_MS=4000
# Hard restart drain timeout.
RESTART_DRAIN_MS=10000
# Card streaming.
STREAM_FIRST_DELAY_MS=150
STREAM_INTERVAL_MS=800
STREAM_HEARTBEAT_MS=5000
STREAM_TOOL_HISTORY_MAX=12
# Shell ! command.
SHELL_TIMEOUT=60
SHELL_OUTPUT_LIMIT=3500
# Reaction emoji while query in flight.
TYPING_EMOJI=Typing
# Resume listing limit (claude only).
RESUME_LIST_LIMIT=20

# --- lark-cli binary (resolved from PATH if unset) ---
# LARK_BIN=lark-cli
